# Nyaya Backend — Environment Variables
# Copy this file to .env and fill in your values.

# --- Qdrant (Vector DB) ---
QDRANT_HOST=https://your-qdrant-instance.gcp.cloud.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=sri_lankan_cases

# --- Neo4j (Graph DB) ---
NEO4J_URI=neo4j+s://your-neo4j-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# --- Azure OpenAI (Primary LLM) ---
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5-nano
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- Gemini (Fallback LLM) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Optional Settings ---
NYAYA_API_KEY=                  # Set to require X-API-Key header on all requests
CORS_ORIGINS=http://localhost:3000  # Comma-separated allowed frontend URLs
NYAYA_DISABLE_GRAPH=0           # Set to 1 to disable Neo4j graph queries
NYAYA_APPEND_DISCLAIMER=1       # Set to 0 to disable legal disclaimer on answers
NYAYA_RERANKER=0                # Set to 1 to enable cross-encoder re-ranking
